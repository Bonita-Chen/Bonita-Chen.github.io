# Google Analytics 4 Measurement ID
# Get this from Google Analytics > Admin > Data Streams > Your Stream > Measurement ID
# Format: G-XXXXXXXXXX (not UA-XXXXXXXXX-X which was for Universal Analytics)
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# GitHub login for /admin online save
AUTH_SECRET=replace-with-a-long-random-string
AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret

# Repository write access used by the server-side save route
GITHUB_REPO_WRITE_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
GITHUB_ADMIN_LOGINS=Bonita-Chen

# Repo metadata for GitHub edit links and save targets
NEXT_PUBLIC_GITHUB_REPO_SLUG=Bonita-Chen/Bonita-Chen.github.io
NEXT_PUBLIC_GITHUB_REPO_BRANCH=main
